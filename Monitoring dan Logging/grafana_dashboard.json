{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.2" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Rain in Australia — ML Monitoring Dashboard | Hafid",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Total Requests",
      "type": "stat",
      "targets": [{ "expr": "sum(inference_requests_total)", "legendFormat": "Total" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Avg Latency",
      "type": "stat",
      "targets": [{ "expr": "rate(inference_latency_seconds_sum[5m]) / rate(inference_latency_seconds_count[5m])", "legendFormat": "Avg Latency" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          },
          "unit": "percentunit",
          "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Model Accuracy",
      "type": "stat",
      "targets": [{ "expr": "model_accuracy_score", "legendFormat": "Accuracy" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "unit": "percentunit",
          "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Data Drift Score",
      "type": "stat",
      "targets": [{ "expr": "data_drift_score", "legendFormat": "Drift" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Active Requests",
      "type": "stat",
      "targets": [{ "expr": "active_requests", "legendFormat": "Active" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "title": "Total Errors",
      "type": "stat",
      "targets": [{ "expr": "sum(error_requests_total)", "legendFormat": "Errors" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Request & Latency Monitoring",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": { "tooltip": { "mode": "single" } },
      "title": "Request Rate (per second)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(inference_requests_total{status='success'}[1m])", "legendFormat": "Success" },
        { "expr": "rate(inference_requests_total{status='error'}[1m])", "legendFormat": "Error" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": { "tooltip": { "mode": "single" } },
      "title": "Inference Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(inference_latency_seconds_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(inference_latency_seconds_bucket[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(inference_latency_seconds_bucket[5m]))", "legendFormat": "P99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Model Performance Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Model Metrics (Accuracy / Precision / Recall / F1)",
      "type": "timeseries",
      "targets": [
        { "expr": "model_accuracy_score",   "legendFormat": "Accuracy" },
        { "expr": "model_precision_score",  "legendFormat": "Precision" },
        { "expr": "model_recall_score",     "legendFormat": "Recall" },
        { "expr": "model_f1_score",         "legendFormat": "F1 Score" },
        { "expr": "model_roc_auc_score",    "legendFormat": "ROC-AUC" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 10,
      "options": { "tooltip": { "mode": "single" } },
      "title": "Prediction Distribution (Hujan vs Tidak Hujan)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(predictions_rain_total[5m])",    "legendFormat": "☔ Hujan (1)" },
        { "expr": "rate(predictions_no_rain_total[5m])", "legendFormat": "☀️ Tidak Hujan (0)" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Confidence Score & Data Drift",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 11,
      "options": { "tooltip": { "mode": "single" } },
      "title": "Confidence Score (avg) & Data Drift Score",
      "type": "timeseries",
      "targets": [
        { "expr": "prediction_confidence_avg", "legendFormat": "Confidence Avg" },
        { "expr": "data_drift_score",          "legendFormat": "Drift Score" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "System Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 12,
      "options": { "tooltip": { "mode": "single" } },
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "targets": [{ "expr": "system_cpu_usage_percent", "legendFormat": "CPU %" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 13,
      "options": { "tooltip": { "mode": "single" } },
      "title": "Memory Usage (%)",
      "type": "timeseries",
      "targets": [{ "expr": "system_memory_usage_percent", "legendFormat": "Memory %" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "id": 14,
      "options": { "tooltip": { "mode": "single" } },
      "title": "Disk Usage (%)",
      "type": "timeseries",
      "targets": [{ "expr": "system_disk_usage_percent", "legendFormat": "Disk %" }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mlops", "rain-aus", "hafid"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Hafid - Rain in Australia ML Dashboard",
  "uid": "rain-aus-hafid",
  "version": 1
}
