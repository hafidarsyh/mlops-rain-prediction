{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "Rain-AUS ML Alerts — Hafid",
      "folder": "MLOps Alerts",
      "interval": "1m",
      "rules": [

        {
          "uid": "alert-high-latency",
          "title": "[Alert 1] High Inference Latency",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 300, "to": 0 },
              "datasourceUid": "prometheus",
              "model": {
                "expr": "histogram_quantile(0.95, rate(inference_latency_seconds_bucket[5m]))",
                "instant": true,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "A"
              }
            },
            {
              "refId": "C",
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 },
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [1.0], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["A"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "expression": "A",
                "hide": false,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "C",
                "type": "threshold"
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "2m",
          "annotations": {
            "description": "Latency P95 melebihi 1 detik selama 2 menit terakhir. Nilai saat ini: {{ $values.A }}s",
            "runbook_url": "",
            "summary": "Latency model terlalu tinggi — perlu investigasi"
          },
          "labels": {
            "severity": "critical",
            "team":     "mlops",
            "author":   "Hafid"
          },
          "isPaused": false
        },

        {
          "uid": "alert-model-accuracy-drop",
          "title": "[Alert 2] Model Accuracy Degradation",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "datasourceUid": "prometheus",
              "model": {
                "expr": "model_accuracy_score",
                "instant": true,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "A"
              }
            },
            {
              "refId": "C",
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 },
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [0.75], "type": "lt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["A"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "expression": "A",
                "hide": false,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "C",
                "type": "threshold"
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "5m",
          "annotations": {
            "description": "Akurasi model turun di bawah 75% (nilai: {{ $values.A }}). Model mungkin perlu di-retrain.",
            "summary": "Performa model menurun — pertimbangkan retraining"
          },
          "labels": {
            "severity": "warning",
            "team":     "mlops",
            "author":   "Hafid"
          },
          "isPaused": false
        },

        {
          "uid": "alert-data-drift",
          "title": "[Alert 3] Data Drift Detected",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "datasourceUid": "prometheus",
              "model": {
                "expr": "data_drift_score",
                "instant": true,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "A"
              }
            },
            {
              "refId": "C",
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 },
              "datasourceUid": "-100",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [0.5], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["A"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "-100" },
                "expression": "A",
                "hide": false,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "C",
                "type": "threshold"
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "5m",
          "annotations": {
            "description": "Skor data drift melebihi 0.5 (nilai: {{ $values.A }}). Distribusi input berbeda signifikan dari data training.",
            "summary": "Data drift terdeteksi — distribusi input berubah"
          },
          "labels": {
            "severity": "warning",
            "team":     "mlops",
            "author":   "Hafid"
          },
          "isPaused": false
        }

      ]
    }
  ]
}
